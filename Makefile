# =========================================================================
# 1. COMPILER SETTINGS
# =========================================================================
CC = cc
CFLAGS = -Wall -Wextra -Werror -Iinclude -O2

# =========================================================================
# 2. PROJECT FILES
# =========================================================================
TARGET = monbsd
SRCS = src/main.c src/hw_pci.c src/sensors_os.c   
OBJS = ${SRCS:.c=.o}

# =========================================================================
# 3. LINKING PHASE (Glues .o files into the final executable)
# =========================================================================
all: ${TARGET}

${TARGET}: ${OBJS}
	${CC} ${CFLAGS} -o $@ ${OBJS}

# =========================================================================
# 4. COMPILATION PHASE (Translates .c to .o)
# =========================================================================
.c.o:
	${CC} ${CFLAGS} -c $< -o $@

# =========================================================================
# 5. CLEANUP
# =========================================================================
clean:
	rm -f ${TARGET} ${OBJS}
